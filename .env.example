# Required later only for backend Authorization Code exchange.
TELEGRAM_LOGIN_CLIENT_SECRET=
TELEGRAM_LOGIN_ISSUER=https://oauth.telegram.org
TELEGRAM_LOGIN_JWKS_URL=https://oauth.telegram.org/.well-known/jwks.json
TELEGRAM_AUTH_TOKEN_TTL_SEC=3600
TELEGRAM_LOGIN_NONCE_TTL_SEC=600

