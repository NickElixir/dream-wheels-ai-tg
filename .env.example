# =====================================================================
# Скопируй этот файл в .env и заполни своими значениями.
# Файл .env УЖЕ в .gitignore — НИКОГДА не коммить реальные ключи.
# =====================================================================

# ---------- Render MCP (для Claude Code) ----------
# Получить: https://dashboard.render.com/u/settings#api-keys
# Формат: rnd_xxxxxxxxxxxxxxxxxxxxxxxx
RENDER_API_KEY=

# Workspace ID (Settings → General в дашборде Render)
# Формат: tea-xxxxxxxxxxxxxxxxxxxx
RENDER_WORKSPACE_ID=

# ---------- Supabase MCP (для Claude Code) ----------
# Project Ref берётся из URL дашборда: https://supabase.com/dashboard/project/<ЭТО>
SUPABASE_PROJECT_REF=

# Personal Access Token: https://supabase.com/dashboard/account/tokens → Generate new token
# Формат: sbp_xxxxxxxxxxxxxxxxxxxx
SUPABASE_ACCESS_TOKEN=

# ---------- Upstash MCP (для Claude Code) ----------
# ВНИМАНИЕ: требует установленного Node.js (brew install node)
# Email от аккаунта Upstash
UPSTASH_EMAIL=

# API Key: https://console.upstash.com → Account → Management API
# Рекомендую создать READ-ONLY ключ — безопаснее
UPSTASH_API_KEY=

# ---------- Backend (main.py) ----------
# PostgreSQL connection string (Render → Postgres → Internal Database URL)
DATABASE_URL=

# Redis connection string (Render → Redis → Internal Redis URL)
REDIS_URL=

# Reve API (https://reve.com → API keys)
REVE_API_KEY=

# Supabase service_role key — обходит RLS, для серверных операций (загрузка
# в Storage, чтение/запись таблиц от имени сервиса). НИКОГДА не светить
# на клиенте/в логах.
# Где взять: Supabase Dashboard → Settings → API Keys → "service_role" → Reveal
# Формат: eyJhbGciOiJIUzI1... (длинный JWT)
SUPABASE_SERVICE_ROLE_KEY=

# Публичный базовый URL сервиса — используется для построения ссылок
# на сгенерированные картинки в static/. БЕЗ trailing slash.
# Production: https://dream-wheels-ai-tg.onrender.com
# Локально:   http://127.0.0.1:10000
# Если не задан — используется onrender.com URL по умолчанию.
PUBLIC_BASE_URL=https://dream-wheels-ai-tg.onrender.com

# ---------- Telegram bot (bot.py) ----------
# Получить у @BotFather в Telegram
BOT_TOKEN=

# URL FastAPI бэкенда. Локально: http://127.0.0.1:10000
# В продакшене: https://dream-wheels-ai-tg.onrender.com
API_BASE_URL=http://127.0.0.1:10000
WEBAPP_URL=https://dream-wheels-ai-webapp.vercel.app

# ---------- Wheel segmentation (Stage 1, src/wheel_seg.py) ----------
# Путь к YOLOv11n-seg ONNX-модели. Получить через scripts/download_yolo_seg.py
# или экспортить из ultralytics: yolo export model=yolov11n-seg.pt format=onnx
WHEEL_SEG_MODEL_PATH=models/yolov11n-seg.onnx

# ID класса «колесо» в подгруженной модели. Для wheel-fine-tuned single-class
# модели — обычно 0; для COCO-pretrained пригодных классов нет.
WHEEL_SEG_CLASS_ID=0

# Опциональный URL для прямого скачивания .onnx через scripts/download_yolo_seg.py
# YOLO_SEG_DOWNLOAD_URL=

# Roboflow API key для локальной проверки hosted instance segmentation
# через scripts/roboflow_probe.py. Получить: https://app.roboflow.com/settings/api
ROBOFLOW_API_KEY=

# ---------- VLM wheel-mask filter (Stage 2 smoke tests) ----------
# OpenAI-compatible vision provider for scripts/vlm_mask_filter_probe.py.
# Zveno example:
#   VLM_BASE_URL=https://api.zveno.ai/v1
#   VLM_MODEL=qwen/qwen3-vl-30b-a3b-instruct
# Quality benchmark candidate:
#   VLM_MODEL=qwen/qwen3-vl-235b-a22b-instruct
VLM_BASE_URL=
VLM_API_KEY=
VLM_MODEL=

# ---------- fal.ai masked inpainting evaluation (paid, local only) ----------
# Получить: https://fal.ai/dashboard/keys
# Используется scripts/fal_inpaint_eval.py только с явным флагом --execute.
# Скрипт перед запуском считает cost estimate и падает, если он выше
# --max-estimated-cost. Рекомендуемый первый tuning лимит: 1.00 USD.
# Пример:
#   .venv/bin/python scripts/fal_inpaint_eval.py tmp/fal-inpaint-eval/cases-rim1-1024.jsonl \
#     --preset tuning --limit 5 --max-estimated-cost 1.00 --execute
FAL_KEY=

# ---------- OpenAI image edit evaluation (paid, local only) ----------
# Получить: https://platform.openai.com/api-keys
# Используется scripts/openai_image_edit_eval.py только с явным флагом --execute.
OPENAI_API_KEY=
