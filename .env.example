# =====================================================================
# Скопируй этот файл в .env и заполни своими значениями.
# Файл .env УЖЕ в .gitignore — НИКОГДА не коммить реальные ключи.
# =====================================================================

# ---------- Render MCP (для Claude Code) ----------
# Получить: https://dashboard.render.com/u/settings#api-keys
# Формат: rnd_xxxxxxxxxxxxxxxxxxxxxxxx
RENDER_API_KEY=

# Workspace ID (Settings → General в дашборде Render)
# Формат: tea-xxxxxxxxxxxxxxxxxxxx
RENDER_WORKSPACE_ID=

# ---------- Supabase MCP (для Claude Code) ----------
# Project Ref берётся из URL дашборда: https://supabase.com/dashboard/project/<ЭТО>
SUPABASE_PROJECT_REF=

# Personal Access Token: https://supabase.com/dashboard/account/tokens → Generate new token
# Формат: sbp_xxxxxxxxxxxxxxxxxxxx
SUPABASE_ACCESS_TOKEN=

# ---------- Upstash MCP (для Claude Code) ----------
# ВНИМАНИЕ: требует установленного Node.js (brew install node)
# Email от аккаунта Upstash
UPSTASH_EMAIL=

# API Key: https://console.upstash.com → Account → Management API
# Рекомендую создать READ-ONLY ключ — безопаснее
UPSTASH_API_KEY=

# ---------- Backend (main.py) ----------
# PostgreSQL connection string (Render → Postgres → Internal Database URL)
DATABASE_URL=

# Redis connection string (Render → Redis → Internal Redis URL)
REDIS_URL=

# Reve API (https://reve.com → API keys)
REVE_API_KEY=

# Supabase service_role key — обходит RLS, для серверных операций (загрузка
# в Storage, чтение/запись таблиц от имени сервиса). НИКОГДА не светить
# на клиенте/в логах.
# Где взять: Supabase Dashboard → Settings → API Keys → "service_role" → Reveal
# Формат: eyJhbGciOiJIUzI1... (длинный JWT)
SUPABASE_SERVICE_ROLE_KEY=

# Публичный базовый URL сервиса — используется для построения ссылок
# на сгенерированные картинки в static/. БЕЗ trailing slash.
# Production: https://dream-wheels-ai-tg.onrender.com
# Локально:   http://127.0.0.1:10000
# Если не задан — используется onrender.com URL по умолчанию.
PUBLIC_BASE_URL=https://dream-wheels-ai-tg.onrender.com

# ---------- Telegram bot (bot.py) ----------
# Получить у @BotFather в Telegram
BOT_TOKEN=

# URL FastAPI бэкенда. Локально: http://127.0.0.1:10000
# В продакшене: https://dream-wheels-ai-tg.onrender.com
API_BASE_URL=http://127.0.0.1:10000
WEBAPP_URL=https://dream-wheels-ai-webapp.vercel.app
